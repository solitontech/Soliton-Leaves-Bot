# Bot Configuration
BOT_APP_ID=your-bot-app-id-here
BOT_APP_SECRET=your-bot-app-secret-here

# Azure AD Configuration
TENANT_ID=your-tenant-id-here

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.2

# Server Configuration
PUBLIC_URL=https://your-public-url-here
MONITORED_EMAIL=your-monitored-email@example.com

# Default leave type when none is specified in the email
# Defaults to "Sick Leave" if not set
DEFAULT_LEAVE_TYPE=Sick Leave

# SSL Configuration (Required for HTTPS - Microsoft Graph requires HTTPS)
# Set USE_HTTPS=true and provide paths to your SSL certificate files
# OR use a reverse proxy (nginx/apache) to handle SSL
USE_HTTPS=false
SSL_KEY_PATH=/path/to/privkey.pem
SSL_CERT_PATH=/path/to/fullchain.pem

# GreytHR Configuration
GREYTHR_API_URL=https://api.greythr.com/leave/v2
GREYTHR_AUTH_URL=https://your-greythr-auth-url
GREYTHR_DOMAIN=your-greythr-domain
GREYTHR_USERNAME=your-greythr-username
GREYTHR_PASSWORD=your-greythr-password

# Company Email Domain (used to verify sender is from the organization)
COMPANY_EMAIL_DOMAIN=solitontech.com
